rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      // Allow read if the user is either the tenant or the landlord
      allow read: if request.auth != null &&
                  (request.auth.uid == resource.data.tenantId ||
                   request.auth.uid == resource.data.landlordId);

      // Allow create if the user is the tenant and the tenantId matches the auth uid
      allow create: if request.auth != null &&
                    request.auth.uid == request.resource.data.tenantId;

      // Allow update if the user is the landlord and they are only updating the status and/or message
      allow update: if request.auth != null &&
                    request.auth.uid == resource.data.landlordId &&
                    request.resource.data.keys().hasOnly(['status', 'message']);

      // Allow delete (cancel) if the user is the tenant
      allow delete: if request.auth != null &&
                    request.auth.uid == resource.data.tenantId;
    }
  }
}